# =============================================================================
# Telegram Support Bot - Environment Configuration
# Copy this file to ".env" and fill in real values before running the bot.
# =============================================================================

# Telegram bot token from @BotFather
BOT_TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://support_bot:support_bot_password@postgres:5432/support_bot

# Telegram group (chat) ID where all appeals are forwarded.
# Must be a supergroup. Use a negative ID, e.g. -1001234567890
GROUP_ID=-1001234567890

# Telegram user ID of the super administrator (full access, cannot be revoked)
SUPER_ADMIN_ID=123456789

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional / advanced settings (sensible defaults are provided in code)
# -----------------------------------------------------------------------------

# PostgreSQL credentials used by docker-compose to bootstrap the container
POSTGRES_USER=support_bot
POSTGRES_PASSWORD=support_bot_password
POSTGRES_DB=support_bot

# Flood control: minimum seconds between messages from the same user
THROTTLE_RATE_LIMIT=0.7

# Maximum number of attachments allowed per appeal
MAX_ATTACHMENTS_PER_APPEAL=20

# Directory (inside container) where log files are stored
LOG_DIR=logs

# Timezone used for statistics/date formatting
TIMEZONE=Asia/Tashkent
